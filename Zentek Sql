CREATE PROCEDURE [dbo].[sp_create_products]
    @Name NVARCHAR(100),
    @Price DECIMAL(18,2),
    @Description NVARCHAR(255)
AS
BEGIN
    INSERT INTO Products(Name, Price, Description, CreatedAt)
    VALUES(@Name, @Price, @Description, GETDATE())
END
