CREATE PROCEDURE [dbo].[sp_select_product]
    @Color NVARCHAR(50)
AS
BEGIN
    SELECT Id, Name, Price, Description, CreatedAt FROM Products WHERE Description LIKE '%' + @Color + '%'
END
